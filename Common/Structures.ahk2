  int    iGroupId;
  UINT   cColumns;
  PUINT  puColumns;
  int    *piColFmt;
  int    iGroup;
} LVITEMA, *LPLVITEMA;
*/
Struct stLVITEM extends baseStructure {
  mask      : UInt32
  iItem     : Int32
  iSubItem  : Int32

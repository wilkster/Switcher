#Requires AutoHotkey v2.1-alpha.23
/************************************************************************
 * @description Various Structures used throughout
 * @file Structures.ahk2
 * @author Tom Wilkason
 * @date 2024/02/17
 * @version 1.0.0
 ***********************************************************************/
#include dllFactory.ahk2
/**** D A T A    T Y P E S
 *    i8, i16, Int32 and i64 are signed integers, with Int32 being 32-bit.
 *    UInt8, u16, UInt32 and u64 are unsigned integers, with UInt32 being 32-bit.
 *    iptr and IntPtr are integers; 32-bit when A_PtrSize = 4 and 64-bit when A_PtrSize = 8.
 *    f32 and f64 are floating-point numbers.
 */
;----------------------------------------------------------------------
; Base Structure with common utility methods
;----------------------------------------------------------------------
Struct baseStructure {
   CopyTo(objTarget) {
      ; Don't necessarly need the propery names to match, but they have to be the same size
      if (this.Size > 0 AND objTarget.Size = this.Size) {
         DllCall("RtlCopyMemory", "Ptr", objTarget.Ptr, "Ptr", this.Ptr, "Uint", this.Size)
         Return 1
      } else  {
         Error("Object Size Mismatch on " this.__Class, -1, objTarget.__Class)
      }
   }
}
/*

https://stackoverflow.com/questions/72243620/nmhdr-definition-conflict
typedef struct tagNMHDR { from winuser.h
  HWND     hwndFrom;
  UINT_PTR idFrom;5  UINT     code;
  nweed pad for next ptr
} NMHDR;

typedef struct tagNMCUSTOMDRAWINFO {
  NMHDR     hdr;
  DWORD     dwDrawStage;
  HDC       hdc;
  RECT      rc;
  DWORD_PTR dwItemSpec;
  UINT      uItemState;
  LPARAM    lItemlParam;
} NMCUSTOMDRAW, *LPNMCUSTOMDRAW;

typedef struct tagNMLVCUSTOMDRAW {
  NMCUSTOMDRAW nmcd;

  COLORREF     clrText;
  COLORREF     clrTextBk;
  int          iSubItem;
  DWORD        dwItemType;
  COLORREF     clrFace;
  int          iIconEffect;
  int          iIconPhase;
  int          iPartId;
  int          iStateId;
  RECT         rcText;
  UINT         uAlign;
} NMLVCUSTOMDRAW, *LPNMLVCUSTOMDRAW;
*/
;----------------------------------------------------------------------
; Complicated nested structures for listview custom drawing
;----------------------------------------------------------------------
Struct stNMHDR extends baseStructure {
   hwndFrom: IntPtr ; A window handle to the control sending the message. cls.nmc.nmhdr.hwndFrom
   idFrom  : IntPtr   ; An identifier of the control sending the message.
   code    : UInt32      ; A notification code. (NM_CUSTOMDRAW = -12)
}
Struct stNMCUSTOMDRAW extends baseStructure {
   nmhdr      : stNMHDR   ; adjusts for needed padding
   dwDrawStage: UInt32       ; Need to determine stage
   hdc        : IntPtr      ; Can use to select a font into to change it
   rc         : stRECT
   dwItemSpec : IntPtr      ; Need, Row Number (0 based)
   uItemState : UInt32       ; Need, to adjust state
   lItemlParam: IntPtr      ; Application Specific (unused)

}
;----------------------------------------------------------------------
; Top level class, handling shifting of internal classes
; Whole thing is 136 bytes on win64
; https://learn.microsoft.com/en-us/windows/win32/api/commctrl/ns-commctrl-nmlvcustomdraw
;----------------------------------------------------------------------
Struct stNMLVCUSTOMDRAW extends baseStructure {
   nmc      : stNMCUSTOMDRAW
   clrText  : UInt32       ; Need, text foreground color
   clrTextBk: UInt32       ; Need, text background color
   iSubItem : Int32       ; Need, Col, ignore the rest
   ; Control Version 6.0+ below, unused don't think they work here
   dwItemType : UInt32     ; DWORD that contains the type of the item to draw. This member can be one of the following values.
   clrFace    : UInt32     ; COLORREF value representing the color that will be used to display the face of an item.
   iIconEffect: Int32     ; Value of type int that specifies the effect that is applied to an icon, such as Glow, Shadow, or Pulse. Non-Report view I think
   iIconPhase : Int32
   iPartId    : Int32
   iStateId   : Int32
   rcText     : stRECT ; RECT that specifies the rectangle in which the text is to be drawn.
   uAlign     : UInt32
}
/*
typedef struct tagLVITEMA {
  UINT   mask;
  int    iItem;
  int    iSubItem;
  UINT   state;
  UINT   stateMask;
  LPSTR  pszText;
  int    cchTextMax;
  int    iImage;
